  "item": [
    {
      "name": "1. Authentication & User Signup",
      "item": [
        {
          "name": "Signup Author 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Author 1 signup successful\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200]);",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.errors).to.be.undefined;",
                  "  pm.expect(res.data.signup.token).to.exist;",
                  "  pm.expect(res.data.signup.refreshToken).to.exist;",
                  "  pm.expect(res.data.signup.user.id).to.exist;",
                  "  pm.expect(res.data.signup.user.name).to.equal('Author One');",
                  "  pm.expect(res.data.signup.user.role).to.equal('author');",
                  "  pm.environment.set('author1_token', res.data.signup.token);",
                  "  pm.environment.set('author1_refresh_token', res.data.signup.refreshToken);",
                  "  pm.environment.set('author1_id', res.data.signup.user.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"mutation { signup(input: {name: \\\"Author One\\\", email: \\\"author1-{{$timestamp}}@test.com\\\", password: \\\"password123\\\"}) { token refreshToken user { id name email role } } }\"}"
            },
            "url": {
              "raw": "{{graphql_endpoint}}",
              "host": ["{{graphql_endpoint}}"]
            }
          }
        },
        {
          "name": "Signup Author 2",
          "event": [
            {
